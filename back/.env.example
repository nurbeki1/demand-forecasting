# ============================================================
# REQUIRED VARIABLES
# ============================================================

# JWT Secret Key - REQUIRED
# Must be at least 32 characters long and NOT a placeholder value
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# OpenAI API Key (required for AI chat)
OPENAI_API_KEY=your_openai_api_key_here


# ============================================================
# OPTIONAL VARIABLES
# ============================================================

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60    # Default: 60 (1 hour)
REFRESH_TOKEN_EXPIRE_DAYS=7       # Default: 7 days

# Rate Limiting
RATE_LIMIT_ENABLED=true           # Default: true
RATE_LIMIT_AUTH_PER_MINUTE=5      # Default: 5
RATE_LIMIT_CHAT_PER_MINUTE=20     # Default: 20
RATE_LIMIT_DEFAULT_PER_MINUTE=100 # Default: 100

# Additional CORS Origins (comma-separated)
# CORS_ORIGINS=https://myapp.com,https://admin.myapp.com

# Database URL (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend URL for CORS (also added to allowed origins)
FRONTEND_URL=http://localhost:5173

# Support — shown in Telegram support bot (/start, /help, /support). Optional.
# SUPPORT_EMAIL=support@example.com

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your_google_client_id_here

# Telegram Bot (optional)
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Internal supergroup for human support: bot forwards Отзыв/Запрос here; operators reply to that message (reply thread).
# TELEGRAM_SUPPORT_GROUP_ID=-1001234567890
# Optional comma-separated Telegram user IDs allowed to relay replies to users (omit = anyone in the group can reply).
# TELEGRAM_SUPPORT_OPERATOR_IDS=111111111,222222222
