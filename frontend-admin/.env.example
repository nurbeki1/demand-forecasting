# Backend root URL (no trailing slash). Omit in dev to use http://127.0.0.1:8000 by default.
# Use your Railway/production URL when testing dev against the cloud API.
# VITE_API_URL=https://your-api.example.com
#
# Wrong: https://host/api  → use https://host (paths are /auth/..., /chat, ...)
VITE_API_URL=http://127.0.0.1:8000

# Telegram — Enterprise / support button opens this link (full URL or @BotUsername)
# Example: https://t.me/your_demand_bot   or   your_demand_bot
# Optional deep link so /start shows support menu first: https://t.me/your_demand_bot?start=support
# VITE_TELEGRAM_SUPPORT_URL=
